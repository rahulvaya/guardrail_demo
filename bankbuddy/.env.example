# =============================================================================
# BankBuddy - environment configuration template
# Copy to `.env` and adjust. NEVER commit a real `.env`.
# =============================================================================

# --- UI ---
UI_PORT=8080
# URL the React app uses to reach the public API. Browser-side, so use localhost.
PUBLIC_API_BASE_URL=http://localhost:8000
# Origin the api accepts for CORS (browser origin of the UI).
PUBLIC_UI_ORIGIN=http://localhost:8080

# --- API (public BFF) ---
API_PORT=8000
APP_JWT_SECRET=change-me-please
APP_JWT_TTL_SECONDS=3600

# --- Auth (abstracted via IAuthProvider) ---
# Options: local-dev | entra | auth0 | keycloak | cognito
AUTH_PROVIDER=local-dev
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=http://localhost:8080/auth/callback

# --- Agent (INTERNAL ONLY - not exposed to host) ---
AGENT_INTERNAL_URL=http://agent:8100
# Shared secret between api and agent. Rotate in production. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
AGENT_INTERNAL_TOKEN=please-rotate-this-token
# Options: langgraph | foundry | openai-assistants | bedrock
AGENT_PROVIDER=langgraph

# --- LLM gateway (LiteLLM, abstracted via ILLMClient) ---
# Options: ollama | openai | azure | bedrock | vllm
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1:8b
LLM_API_KEY=
# For Ollama running on the host while services run in Docker:
LLM_BASE_URL=http://host.docker.internal:11434
# Required for Azure OpenAI:
# LLM_API_VERSION=2024-08-01-preview

# --- Entra ID service principal (only needed when LLM_PROVIDER=azure and LLM_API_KEY is empty) ---
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# --- Banking backend (abstracted via IBankingService) ---
# Options: mock | real
BANKING_BACKEND=mock
MOCK_BANK_URL=http://mock-bank:8200

# --- PostgreSQL (single instance, three schemas: app | agent_memory | bank) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=bankbuddy
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=postgres

APP_DB_USER=app_user
APP_DB_PASSWORD=app_pw
AGENT_DB_USER=agent_user
AGENT_DB_PASSWORD=agent_pw
BANK_DB_USER=bank_user
BANK_DB_PASSWORD=bank_pw

# --- Sessions / Memory (abstracted via ISessionStore) ---
# Options: postgres | memory
SESSION_STORE=postgres
# Options: postgres | memory
AGENT_CHECKPOINTER=postgres

# --- Secrets (abstracted via ISecretProvider) ---
# Options: env | azure-kv | aws-sm | vault
SECRET_PROVIDER=env

# --- Telemetry (abstracted via ITelemetry) ---
TELEMETRY_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=

# =============================================================================
# GUARDRAILS - single place for every guardrails knob
# -----------------------------------------------------------------------------
# All three groups below are read from this one .env file. The agent container
# uses (1); the guardrails container uses (2) and (3). Listed together so you
# only have to edit one file.
# =============================================================================

# --- (1) Agent-side connection ---
# Master switch. When false, the agent skips all guardrails calls.
GUARDRAILS_ENABLED=true
# Internal DNS name + port of the guardrails container.
GUARDRAILS_URL=http://guardrails:8001
# Bearer token presented by the agent and validated by the guardrails service.
# Rotate before any non-dev environment.
GUARDRAILS_INTERNAL_TOKEN=please-rotate-this-token
# Policy bundle the guardrails service should apply for this agent.
GUARDRAILS_POLICY_ID=bankbuddy-default
# Default policy used by the guardrails service when a request omits policy_id.
GUARDRAILS_DEFAULT_POLICY_ID=bankbuddy-default
# Per-call HTTP timeout (seconds). Input timeouts fail-closed (BLOCK);
# output timeouts fail-open (ALLOW with audit-log entry).
GUARDRAILS_TIMEOUT_SECONDS=5.0
# User-facing message returned when any guard BLOCKS (input or output).
GUARDRAILS_BLOCK_MESSAGE=I'm sorry - I can't help with that request. Please rephrase or ask about your accounts, cards, transfers, ATMs, or loans.

# --- (2) Guard catalog (per-guard ENABLED flags) ---
# Default profile uses Azure AI Content Safety + Azure PII Detection.
# Flip any local guard to true to layer extra checks (regex PII, secrets,
# banned phrases, banking-relevance scoping, etc.).
GUARD_AZURE_CONTENT_SAFETY_ENABLED=true
GUARD_AZURE_PII_DETECTION_ENABLED=true
GUARD_TOKEN_LIMIT_ENABLED=false
GUARD_BANNED_SUBSTRINGS_ENABLED=false
GUARD_PROMPT_INJECTION_ENABLED=false       # covered by Azure Prompt Shields
GUARD_PII_DETECT_ENABLED=false             # enable for regex SSN/card detection
GUARD_BANKING_RELEVANCE_ENABLED=false
GUARD_OUTPUT_PII_REDACT_ENABLED=false      # enable to redact PII in responses
GUARD_SECRET_LEAK_ENABLED=false            # enable to scan for API keys
GUARD_TOXICITY_ENABLED=false               # covered by Azure harm categories
GUARD_COMPETITOR_MENTIONS_ENABLED=false

# Per-guard JSON config (optional). See docs/guardrails.md for keys.
# GUARD_TOKEN_LIMIT_CONFIG={"max_chars": 8000}
# GUARD_PROMPT_INJECTION_CONFIG={"block_threshold": 0.7}
# GUARD_PII_DETECT_CONFIG={"mode": "sanitize", "engine": "regex"}
# GUARD_TOXICITY_CONFIG={"engine": "keyword", "threshold": 0.7}
# GUARD_BANKING_RELEVANCE_CONFIG={"min_ratio": 0.05, "min_length": 25}
# GUARD_COMPETITOR_MENTIONS_CONFIG={"competitors": ["AcmeBank", "GlobalBank"]}
# GUARD_AZURE_CONTENT_SAFETY_CONFIG={"severity_threshold": 4, "categories": ["Hate","SelfHarm","Sexual","Violence"], "fail_open": true}

# --- (3) Provider credentials (Azure AI resources used by the guards) ---
# Azure AI Content Safety (required when GUARD_AZURE_CONTENT_SAFETY_ENABLED=true)
# Endpoint of your Azure AI Content Safety resource, e.g.
#   https://<your-resource>.cognitiveservices.azure.com
AZURE_CONTENT_SAFETY_ENDPOINT=
# Subscription key. Leave empty to use Entra ID via DefaultAzureCredential
# (or AZURE_CONTENT_SAFETY_AAD_TOKEN for a pre-fetched bearer token).
AZURE_CONTENT_SAFETY_KEY=
# AZURE_CONTENT_SAFETY_AAD_TOKEN=

# Azure AI Language (required when GUARD_AZURE_PII_DETECTION_ENABLED=true).
# Defaults to the Content Safety endpoint when both APIs are exposed by the
# same multi-service Cognitive Services / AI Services resource.
AZURE_LANGUAGE_ENDPOINT=
AZURE_LANGUAGE_KEY=
# AZURE_LANGUAGE_AAD_TOKEN=
