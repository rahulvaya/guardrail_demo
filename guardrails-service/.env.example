# =============================================================================
# Guardrails Service - example environment file
#
# Copy to `.env` (gitignored) and edit for your environment, or set these
# in your shell / container runtime. Every URL, auth secret, and tenant
# value the service uses is listed here.
# =============================================================================

# ---- General ----
GUARDRAILS_DEFAULT_POLICY_ID=default
# Single dir, or multiple dirs joined by `;` (Windows) / `:` (Linux/macOS) / `,`.
# Later directories override earlier ones for the same policy id.
# GUARDRAILS_POLICIES_DIR=/app/app/policies:/policies-extra

# ---- Authentication ----
# static | aad | static_or_aad
GUARDRAILS_AUTH_MODE=static_or_aad

# Static bearer token (required for `static` and `static_or_aad`).
# Generate a high-entropy value, e.g. `openssl rand -hex 32`.
GUARDRAILS_INTERNAL_TOKEN=please-rotate-this-token

# ---- Microsoft Entra ID (AAD) ----
# Required when GUARDRAILS_AUTH_MODE is `aad` or `static_or_aad` and you
# expect callers to use Workload Identity / Managed Identity tokens.
# GUARDRAILS_AAD_TENANT_ID=00000000-0000-0000-0000-000000000000
# GUARDRAILS_AAD_AUDIENCE=api://guardrails-service
# Optional CSV of caller app-ids allowed to call /v1/*. Leave unset to
# accept any token issued for the tenant + audience.
# GUARDRAILS_AAD_ALLOWED_APPIDS=11111111-1111-1111-1111-111111111111,22222222-2222-2222-2222-222222222222
# Optional overrides for sovereign clouds / private testing.
# GUARDRAILS_AAD_ISSUER=https://login.microsoftonline.com/<tenant>/v2.0
# GUARDRAILS_AAD_JWKS_URI=https://login.microsoftonline.com/<tenant>/discovery/v2.0/keys

# ---- Azure AI providers (consumed by guards on this pod only) ----
# Either supply endpoint + key (dev) or use Workload Identity (prod) and
# leave KEY values unset.
# AZURE_CONTENT_SAFETY_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
# AZURE_CONTENT_SAFETY_KEY=
# AZURE_LANGUAGE_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
# AZURE_LANGUAGE_KEY=

# Pre-fetched AAD tokens (optional). If set, guards use these instead of
# DefaultAzureCredential. Useful for short-lived dev sessions or when the
# pod has no managed identity but the host does. Tokens must be scoped to
# https://cognitiveservices.azure.com/.default.
# AZURE_CONTENT_SAFETY_AAD_TOKEN=
# AZURE_LANGUAGE_AAD_TOKEN=

# ---- Policy YAML env-var expansion (consumed by the policy loader) ----
# Any policy YAML field may reference an env var as ${VAR} or
# ${VAR:default}. When the whole field value is a single ${VAR}
# reference, the resolved string is JSON-parsed so lists / numbers /
# bools round-trip with the right type. Define one variable per
# guard knob you want to drive from env. Examples below.

# `banned-substrings` phrases as a JSON array string.
# BANNED_PHRASES_JSON=["ignore previous instructions","project zenith"]

# Azure-managed Text Blocklists applied by `azure-content-safety`.
# ACS_BLOCKLIST_NAMES=["corp-blocked-terms"]

# Per-guard ad-hoc config override (JSON dict, merged on top of YAML).
# Format: GUARD_<UPPER_WITH_UNDERSCORES>_CONFIG_OVERRIDE
# GUARD_AZURE_CONTENT_SAFETY_CONFIG_OVERRIDE={"severity_threshold":4}
