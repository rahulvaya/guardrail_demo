# =============================================================================
# Azure AI Evaluation — environment configuration
# =============================================================================
# This file configures the azure-ai-evaluation evaluators in the
# guardrails-service.  It is loaded by docker-compose alongside the main
# bankbuddy/.env so the guardrails container picks up all settings.
#
# NEVER commit this file if it contains real secrets.
# It is already listed in .gitignore (same rule as .env).
# =============================================================================

# -----------------------------------------------------------------------------
# Azure OpenAI — quality / LLM-graded evaluators
# (Groundedness, Coherence, Fluency, Relevance, Similarity, Retrieval, QA)
# -----------------------------------------------------------------------------

# The Azure AI Services resource endpoint (unified services.ai.azure.com format).
# Hosts Azure OpenAI, Content Safety, and the Foundry project for evaluators.
EVAL_AZURE_OPENAI_ENDPOINT=https://aisvc-bankbuddy-rgpz623gyyjhe.services.ai.azure.com/

# Chat-completion deployment used as the judge model.
# Must be a GPT-4 family model for best evaluator accuracy.
EVAL_AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# API version for the Azure OpenAI calls made by the SDK.
EVAL_AZURE_OPENAI_API_VERSION=2024-08-01-preview

# API key — leave empty to use Entra ID (service principal via AZURE_CLIENT_*
# env vars already set in the container, picked up by DefaultAzureCredential).
EVAL_AZURE_OPENAI_API_KEY=

# Pre-fetched bearer token for the azure-ai-evaluation SDK quality evaluators.
# The SDK internally requests tokens with scope https://ai.azure.com/.default,
# so this token must be fetched with that resource, NOT cognitiveservices.azure.com.
# Populate by running: bankbuddy/tools/refresh-aad-token.ps1  (sets EVAL_AZURE_AAD_TOKEN)
# Tokens expire in ~60-75 minutes; re-run the script to refresh.
EVAL_AZURE_AAD_TOKEN=

# -----------------------------------------------------------------------------
# Azure AI Project — safety evaluators
# (Violence, Sexual, Self-Harm, Hate-Unfairness, Indirect-Attack,
#  Protected-Material, ContentSafety composite)
#
# IMPORTANT: Safety evaluators require an ACTUAL Azure AI Foundry project.
# A plain Cognitive Services / Azure AI Services endpoint is NOT sufficient.
# The SDK calls Foundry RAI evaluation APIs that are only available in
# Azure AI Foundry projects (hubs/workspaces).
#
# To enable safety evaluators, create an Azure AI Foundry project in the
# Azure portal, then fill in the three fields below.
# Alternatively, set EVAL_AI_PROJECT_ENDPOINT to a Foundry endpoint URL
# like: https://<name>.services.ai.azure.com/api/projects/<project>
# -----------------------------------------------------------------------------

# Foundry endpoint URL (oneDP path — recognized by services.ai.azure.com or
# api.azureml.ms in the URL).  Plain cognitiveservices.azure.com URLs are
# ignored since they don't host the Foundry RAI evaluation APIs.
# Leave blank and use the triplet below if you don't have a Foundry URL.
EVAL_AI_PROJECT_ENDPOINT=https://aisvc-bankbuddy-rgpz623gyyjhe.services.ai.azure.com/api/projects/bankbuddy-foundry

# -----------------------------------------------------------------------------
# Azure Content Safety — direct API fallback for safety evaluators
# (Violence, Sexual, Self-Harm, Hate-Unfairness, ContentSafety composite)
#
# When the Foundry RAI evaluation service is unavailable in the region,
# safety evaluators fall back to the Azure Content Safety text:analyze API.
# This resource provides the same 4 harm categories (0-6 severity scale)
# using a simpler moderation API that works in all Azure regions.
#
# Uses AZURE_CONTENT_SAFETY_AAD_TOKEN (already fetched by refresh-aad-token.ps1)
# for authentication — no separate token needed.
# -----------------------------------------------------------------------------
EVAL_CONTENT_SAFETY_ENDPOINT=https://cs-bankbuddy-rgpz623gyyjhe.cognitiveservices.azure.com/

# Full Azure AI Foundry project coordinates (required when no endpoint above).
EVAL_AI_PROJECT_SUBSCRIPTION_ID=c2f434b3-f6dd-402a-b106-b3071428d122
EVAL_AI_PROJECT_RESOURCE_GROUP=rg-bankbuddy-aks
EVAL_AI_PROJECT_NAME=bankbuddy-foundry
